#!/usr/bin/env bash
# Wrapper for sidequest-encountergen — generates enemy stat blocks from genre pack data.
# Reads SIDEQUEST_CONTENT_PATH and SIDEQUEST_GENRE from env (set by orchestrator).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BINARY="${SCRIPT_DIR}/../target/debug/sidequest-encountergen"

if [[ ! -x "$BINARY" ]]; then
  BINARY="${SCRIPT_DIR}/../target/release/sidequest-encountergen"
fi

if [[ ! -x "$BINARY" ]]; then
  echo "ERROR: sidequest-encountergen binary not found" >&2
  exit 1
fi

exec "$BINARY" --genre-packs-path "${SIDEQUEST_CONTENT_PATH}" --genre "${SIDEQUEST_GENRE}" "$@"

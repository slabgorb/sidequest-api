#!/usr/bin/env bash
# Wrapper for sidequest-loadoutgen — generates starting equipment from genre pack data.
# Reads SIDEQUEST_CONTENT_PATH and SIDEQUEST_GENRE from env (set by orchestrator).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BINARY="${SCRIPT_DIR}/../target/debug/sidequest-loadoutgen"

if [[ ! -x "$BINARY" ]]; then
  BINARY="${SCRIPT_DIR}/../target/release/sidequest-loadoutgen"
fi

if [[ ! -x "$BINARY" ]]; then
  echo "ERROR: sidequest-loadoutgen binary not found" >&2
  exit 1
fi

exec "$BINARY" --genre-packs-path "${SIDEQUEST_CONTENT_PATH}" --genre "${SIDEQUEST_GENRE}" "$@"
